# ============================================================
# Agent Harness — .gitignore
# ============================================================

# Environment / Secrets
.env
!.env.example
*.pem
*.key
secrets.json
secrets/vault_master_key.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Node / Frontend
node_modules/
frontend/dist/
.npm
*.tgz
.parcel-cache
.vite/

# Data (persisted volumes — don't commit runtime data)
data/db/*.db
data/chroma/
data/workspace/
data/projects/
# Keep default personality templates
!data/personality/
!data/personality/*.md

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
.dockerignore

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db

# Agent-generated meta files (not part of project)
BACKEND_*.txt
BACKEND_*.md
DELIVERY_CHECKLIST.md
FILES_CREATED.txt
backend/BUILD_SUMMARY.txt
backend/INDEX.md
backend/QUICK_REFERENCE.md
backend/BACKEND_BUILD_COMPLETE.md
backend/memory/INDEX.md
backend/memory/MANIFEST.md
backend/memory/QUICK_START.md
backend/memory/SUMMARY.md
backend/memory/VERIFICATION_REPORT.txt
frontend/BUILD_SUMMARY.txt
frontend/COMPLETION_REPORT.md
frontend/INDEX.md
frontend/QUICKSTART.md
