# ============================================================
# Agent Harness — .gitignore
# ============================================================

# Environment / Secrets
.env
!.env.example
*.pem
*.key
secrets.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Node / Frontend
node_modules/
frontend/dist/
.npm
*.tgz
.parcel-cache
.vite/

# Data (persisted volumes — don't commit runtime data)
data/*
# Keep default personality templates
!data/personality/
!data/personality/*.md

# Manual local backups (e.g. data.backup-YYYYMMDD-HHMM/ from migrations)
*.backup-*/
*.backup-*

# Runtime files
.pids

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
.dockerignore

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db

# Stray "build complete" scaffolding artifacts from initial scaffolding.
# The original ones were deleted on 2026-05-24; keep these patterns to
# prevent agent-generated noise from sneaking back in.
BACKEND_*.txt
DELIVERY_CHECKLIST.md
FILES_CREATED.txt
**/BUILD_SUMMARY.txt
**/COMPLETION_REPORT.md
**/BACKEND_BUILD_COMPLETE.md
**/VERIFICATION_REPORT.txt
backend/data/
