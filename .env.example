# ============================================================
# Pantheon — Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# LLM Provider Configuration
# ------------------------------------------------------------
# Configure your primary LLM endpoint.
# (Can be any OpenAI-compatible API such as OpenAI, Ollama, Groq, OpenRouter, etc.)
LLM_BASE_URL=insert-llm-base-url-here
LLM_API_KEY=insert-llm-api-key-here
LLM_MODEL=insert-llm-model-name-here

# Provider Connection Examples:
#
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-proj-...
#   LLM_MODEL=gpt-4o
#
# Ollama (Local):
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=qwen2.5:3b
#
# Groq:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_...
#   LLM_MODEL=llama-3.1-70b-versatile
#
# OpenRouter:
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=sk-or-...
#   LLM_MODEL=anthropic/claude-3.5-sonnet

# Prefill / fast model (optional)
# A cheaper/faster model used for summarization, memory consolidation,
# and background tasks. Leave empty to use LLM_MODEL for everything.
LLM_PREFILL_MODEL=insert-optional-prefill-model-here

# Vision model (optional)
# A vision-capable model for image analysis during file uploads.
# Leave empty to use LLM_MODEL (if it supports vision) with prefill fallback.
LLM_VISION_MODEL=insert-optional-vision-model-here
# Optional separate endpoint/key for the vision model
# VISION_BASE_URL=
# VISION_API_KEY=

# Embedding model
# Used for document indexing and semantic search.
# E.g. text-embedding-3-small (OpenAI) or nomic-embed-text (Ollama)
EMBEDDING_MODEL=insert-embedding-model-here

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# (Automatically populated by deploy.sh if run through installer)
VAULT_MASTER_KEY=change-this-to-a-random-64-char-hex-string-before-deploy
SECRET_KEY=change-this-to-another-random-secret-key-for-jwt
# Password for the web interface. Leave empty to disable auth (not safe on public servers).
AUTH_PASSWORD=insert-auth-password-here

# ------------------------------------------------------------
# Search
# ------------------------------------------------------------
# URL of a search backend. Leave empty to use DuckDuckGo (no key needed).
# SearXNG (self-hosted):  http://localhost:8080
# Brave Search API:       https://api.search.brave.com/res/v1/web/search
# (Automatically populated by deploy.sh if SearXNG option selected)
SEARCH_URL=
# API key if required by the search backend (e.g. Brave Search API key).
SEARCH_API_KEY=

# ------------------------------------------------------------
# Messaging Integrations (optional)
# ------------------------------------------------------------

# Telegram — get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Comma-separated list of allowed Telegram chat IDs
# Leave empty to allow all users (not recommended for production)
TELEGRAM_ALLOWED_CHAT_IDS=

# Discord — create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Comma-separated list of allowed Discord guild (server) IDs
# Leave empty to allow all guilds the bot is in
DISCORD_ALLOWED_GUILD_IDS=

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO
# Comma-separated CORS origins for development
CORS_ORIGINS=http://localhost:8000,http://localhost:5173,http://localhost:80

# ------------------------------------------------------------
# ChromaDB (internal Docker networking — usually no change needed)
# ------------------------------------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ------------------------------------------------------------
# Active Memory & Curation
# ------------------------------------------------------------
# Auto-extraction: run LLM-based entity/fact extraction after this many
# messages per session. Set to 0 to only extract on session consolidation.
# Recommended: 10-20 for active learning, 0 for manual control.
EXTRACTION_INTERVAL=0
# Max tokens of recalled context injected into the system prompt.
RECALL_TOKEN_BUDGET=4000
# Automatically index uploaded files into semantic memory (true/false).
AUTO_INDEX_UPLOADS=true
# Chunk size and overlap for file indexing (in tokens).
FILE_CHUNK_SIZE=500
# Chunk overlap (in tokens).
FILE_CHUNK_OVERLAP=50

# ------------------------------------------------------------
# Docker Build Customizations (Optional)
# ------------------------------------------------------------
# Set to true to build LibreOffice inside the backend container for document preview rendering.
INSTALL_OFFICE=false
# Set to true to install Playwright and Chromium dependencies inside the backend container.
INSTALL_BROWSER=false

# ------------------------------------------------------------
# Data directory (inside container)
# ------------------------------------------------------------
DATA_DIR=/app/data
