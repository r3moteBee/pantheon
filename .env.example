# ============================================================
# Pantheon — Environment Configuration
# Copy this file to .env and fill in your values.
#
# SECRETS (API keys, tokens, passwords) belong in the encrypted
# vault, NOT in this file.  After copying, run:
#
#   python -m secrets.setup              # Interactive setup
#   python -m secrets.setup --migrate    # Auto-migrate from .env
#   python -m secrets.setup --check      # Check status
#
# See README.md § Security for details.
# ============================================================

# ------------------------------------------------------------
# LLM Provider (non-sensitive)
# ------------------------------------------------------------
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Prefill / fast model (optional)
# A cheaper/faster model used for summarization, memory consolidation,
# and background tasks. Leave empty to use LLM_MODEL for everything.
LLM_PREFILL_MODEL=

# Embedding model (defaults to text-embedding-3-small for OpenAI)
EMBEDDING_MODEL=text-embedding-3-small

# Optional separate embedding/prefill/reranker base URLs
# (leave empty to use LLM_BASE_URL)
# EMBEDDING_BASE_URL=
# PREFILL_BASE_URL=
# RERANKER_BASE_URL=
# RERANKER_MODEL=

# ------------------------------------------------------------
# Search (non-sensitive)
# ------------------------------------------------------------
# URL of a search backend. Leave empty to use DuckDuckGo (no key needed).
# SearXNG (self-hosted):  http://localhost:8080
# Brave Search API:       https://api.search.brave.com/res/v1/web/search
SEARCH_URL=

# ------------------------------------------------------------
# Telegram (non-sensitive)
# ------------------------------------------------------------
# Comma-separated list of allowed Telegram chat IDs.
# Leave empty to allow all users (not recommended for production).
TELEGRAM_ALLOWED_CHAT_IDS=

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO
# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ------------------------------------------------------------
# ChromaDB
# ------------------------------------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ------------------------------------------------------------
# Data directory (inside container)
# ------------------------------------------------------------
DATA_DIR=/app/data
